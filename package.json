{
  "name": "fiber-agent-pay",
  "version": "0.1.0",
  "private": true,
  "description": "AI agents executing micropayment strategies via Fiber Network payment channels on CKB",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @fiber-agent-pay/server dev & pnpm --filter @fiber-agent-pay/dashboard dev",
    "build": "pnpm -r build",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  }
}
