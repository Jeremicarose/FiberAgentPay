# Wallet (DO NOT commit real keys)
# Generate one: echo "0x$(openssl rand -hex 32)"
WALLET_PRIVATE_KEY=0x<your-testnet-private-key>

# Network
NETWORK=testnet

# Fiber Network Node (optional — agents run in simulation mode without it)
FIBER_RPC_URL=http://127.0.0.1:8227

# Server
PORT=3001
WS_PORT=3002
